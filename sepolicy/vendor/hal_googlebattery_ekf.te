type hal_googlebattery_ekf, domain;
type hal_googlebattery_ekf_exec, exec_type, file_type, vendor_file_type;

binder_call(hal_googlebattery_ekf, servicemanager)

init_daemon_domain(hal_googlebattery_ekf)

r_dir_file(hal_googlebattery_ekf, sysfs_batteryinfo)

allow hal_googlebattery_ekf fwk_stats_service:service_manager find;
allow hal_googlebattery_ekf logbuffer_device:chr_file r_file_perms;
allow hal_googlebattery_ekf sysfs_batteryinfo:file rw_file_perms;
