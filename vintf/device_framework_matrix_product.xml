<compatibility-matrix version="9.0" type="framework">
    <hal format="aidl">
        <name>android.hardware.biometrics.fingerprint</name>
        <interface>
            <name>IFingerprint</name>
            <instance>default</instance>
        </interface>
    </hal>
    <hal format="aidl">
        <name>com.google.hardware.biometrics.fingerprint.debug</name>
        <interface>
            <name>IFingerprintDebug</name>
            <instance>default</instance>
        </interface>
    </hal>
    <hal format="aidl">
        <name>vendor.google.radio_ext</name>
        <interface>
            <name>IRadioExt</name>
            <instance>default</instance>
        </interface>
    </hal>
    <hal format="aidl">
        <name>vendor.qti.hardware.fingerprint</name>
        <interface>
            <name>IQfpExtendedFingerprint</name>
            <instance>default</instance>
        </interface>
    </hal>
    <hal format="aidl">
        <name>vendor.qti.hardware.fingerprint</name>
        <interface>
            <name>IQfpExtendedSession</name>
            <instance>default</instance>
        </interface>
    </hal>
    <hal format="aidl">
        <name>vendor.qti.hardware.fingerprint</name>
        <interface>
            <name>IQfpExtendedSessionCallback</name>
            <instance>default</instance>
        </interface>
    </hal>
</compatibility-matrix>
