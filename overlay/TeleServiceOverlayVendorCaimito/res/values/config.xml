<resources>
    <!-- Dynamic routing of emergency calls: trying normal routing if it's available.
         Otherwise, emergency routing. -->
    <!-- TODO (b/346398725: temporary code, cleanup) -->
    <bool name="dynamic_routing_emergency_enabled">true</bool>

    <!-- Array of countries that the dynamic routing is supported.
         Values should be ISO3166 country codes in lowercase. -->
    <string-array name="config_countries_dynamic_routing_emergency_enabled">
        <item>mk</item>
        <item>al</item>
        <item>cz</item>
        <item>gr</item>
        <item>hr</item>
        <item>me</item>
        <item>in</item>
        <item>il</item>
        <item>tw</item>
        <item>sg</item>
        <item>ch</item>
        <item>sk</item>
        <item>pl</item>
        <item>si</item>
        <item>ba</item>
    </string-array>

    <!-- Array of emergency numbers for dynamic routing.
         Values are the tuples of Country ISO, MNC, and numbers. -->
    <string-array name="config_dynamic_routing_emergency_numbers">
        <item>mk,,192,193,194,195,196</item>
        <item>al,,125,126,127,128,129</item>
        <item>cz,01,156</item>
        <item>cz,03,156</item>
        <item>gr,,100,108,166,197,199,1056,11188,116000</item>
        <item>hr,,192,193,194,195,1987</item>
        <item>me,,122,123,124</item>
        <item>in,,101,102,103,108</item>
        <item>il,,101,102</item>
        <item>tw,,110,119</item>
        <item>sg,01,995</item>
        <item>sg,02,995</item>
        <item>sg,03,995</item>
        <item>sg,10,995</item>
        <item>ch,,1414</item>
        <item>gp,,115,119,191,196,197,116000,116111,116117</item>
        <item>sk,,159</item>
        <item>pl,,984,985,986,987,989,991,992,993,994,995,996,997,998,999</item>
        <item>re,,115,119,191,196,197,116000,116111,116117</item>
        <item>si,,113</item>
        <item>ba,,122,123,124</item>
    </string-array>

    <!-- The component name(a flattened ComponentName string) for the telephony domain selection
         service. The device should fallback to the modem based domain selection architecture
         if this is not configured. -->
    <string name="config_domain_selection_service_component_name">com.android.phone/com.android.services.telephony.domainselection.TelephonyDomainSelectionService</string>

    <!-- The processes names of the logcat logs that will be collected after an emergency call.-->
    <string-array name="ecc_log_sources_process_names">
        <item>com.android.phone</item>
        <item>com.android.telephony.imsmedia</item>
        <item>com.shannon.imsservice</item>
        <item>com.android.qns</item>
        <item>com.google.android.iwlan</item>
        <item>rild_exynos</item>
        <item>com.samsung.slsi.telephony.oemril</item>
        <item>com.google.android.rilextension</item>
        <item>com.samsung.slsi.telephony.oem.oemrilhookservice</item>
        <item>com.google.android.dialer</item>
        <item>com.android.settings</item>
    </string-array>
</resources>
